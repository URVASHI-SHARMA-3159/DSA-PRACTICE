Time complexity :- O(n/2+n/2)+O(n+n/2)
Space Complexity :- o(1)
#include<iostream>
#include<vector>
#include<algorithm>
using namespace std;
void rotatematrix(vector<vector<int>>& matrix,int n){
    for(int i = 0;i<n-1;i++){
        for(int j = i + 1;j<n;j++){
            swap(matrix[i][j],matrix[j][i]);
        }
    }
    for(int i = 0;i<n;i++){
        reverse(matrix[i].begin(),matrix[i].end());
    }
    
}
int main(){
    int n;
    cin>>n;
    vector<vector<int>> matrix(n,vector<int>(n));
    for(int i = 0;i<n;i++){
        for(int j = 0;j<n;j++){
            cin>>matrix[i][j];
        }
    }
    rotatematrix(matrix,n);
    for(int i = 0;i<n;i++){
        for(int j = 0;j<n;j++){
            cout<<matrix[i][j]<<" ";
        }
        cout<<endl;
    }
}
